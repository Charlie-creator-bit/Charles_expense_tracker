{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Public user profile information",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "createdAt"]
    },
    "Expense": {
      "title": "Expense Record",
      "description": "An expense entry",
      "type": "object",
      "properties": {
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "description": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["amount", "category", "date", "userId", "createdAt"]
    },
    "Income": {
      "title": "Income Record",
      "description": "An income entry",
      "type": "object",
      "properties": {
        "amount": { "type": "number" },
        "source": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["amount", "source", "date", "userId", "createdAt"]
    },
    "Budget": {
      "title": "Budget Management",
      "description": "Monthly budget targets",
      "type": "object",
      "properties": {
        "amount": { "type": "number" },
        "month": { "type": "number" },
        "year": { "type": "number" },
        "userId": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["amount", "month", "year", "userId"]
    },
    "Account": {
      "title": "Linked Account",
      "description": "Linked bank or mobile money account",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["bank", "mobile_money"] },
        "accountNumber": { "type": "string" },
        "lastSync": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "type", "userId", "createdAt"]
    },
    "SMSHistory": {
      "title": "SMS Parse History",
      "description": "Record of SMS messages parsed by AI",
      "type": "object",
      "properties": {
        "originalText": { "type": "string" },
        "parsedData": { "type": "object" },
        "status": { "type": "string", "enum": ["success", "failed"] },
        "transactionId": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["originalText", "userId", "createdAt"]
    },
    "Reminder": {
      "title": "Financial Reminder",
      "description": "Scheduled alert for financial tasks",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "time": { "type": "string", "format": "date-time" },
        "isCompleted": { "type": "boolean" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "time", "userId", "createdAt"]
    }
  },
  "firestore": {
    "users": {
      "schema": "User",
      "description": "Collection of user profiles"
    },
    "expenses": {
      "schema": "Expense",
      "description": "Collection of all expenses"
    },
    "income": {
      "schema": "Income",
      "description": "Collection of all income entries"
    },
    "budgets": {
      "schema": "Budget",
      "description": "Collection of user budgets"
    },
    "accounts": {
      "schema": "Account",
      "description": "Collection of linked banking and MoMo accounts"
    },
    "smsHistory": {
      "schema": "SMSHistory",
      "description": "History of parsed SMS messages"
    },
    "reminders": {
      "schema": "Reminder",
      "description": "User defined reminders and alerts"
    }
  }
}
