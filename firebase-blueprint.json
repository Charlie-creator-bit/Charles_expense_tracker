{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "User's email address."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the user was created."
        }
      },
      "required": ["email", "createdAt"]
    },
    "Expense": {
      "title": "Expense",
      "description": "An individual expense entry.",
      "type": "object",
      "properties": {
        "amount": {
          "type": "number",
          "description": "The amount spent."
        },
        "category": {
          "type": "string",
          "description": "Category of the expense (e.g. Food, Rent)."
        },
        "date": {
          "type": "string",
          "format": "date-time",
          "description": "Date of the expense."
        },
        "description": {
          "type": "string",
          "description": "Brief description of the expense."
        },
        "userId": {
          "type": "string",
          "description": "The UID of the user who owns this expense."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Server-side timestamp."
        }
      },
      "required": ["amount", "category", "date", "description", "userId", "createdAt"]
    },
    "Budget": {
      "title": "Budget",
      "description": "Monthly budget limit.",
      "type": "object",
      "properties": {
        "amount": {
          "type": "number",
          "description": "The budget amount."
        },
        "month": {
          "type": "number",
          "description": "Month index (0-11)."
        },
        "year": {
          "type": "number",
          "description": "Year of the budget."
        },
        "userId": {
          "type": "string",
          "description": "The UID of the user."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Server-side timestamp."
        }
      },
      "required": ["amount", "month", "year", "userId", "createdAt"]
    },
    "Income": {
      "title": "Income",
      "description": "An individual income entry.",
      "type": "object",
      "properties": {
        "amount": {
          "type": "number",
          "description": "The amount earned."
        },
        "category": {
          "type": "string",
          "description": "Category of the income (e.g. Salary, Freelance)."
        },
        "date": {
          "type": "string",
          "format": "date-time",
          "description": "Date of the income."
        },
        "description": {
          "type": "string",
          "description": "Brief description of the income."
        },
        "userId": {
          "type": "string",
          "description": "The UID of the user who owns this income."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Server-side timestamp."
        }
      },
      "required": ["amount", "category", "date", "description", "userId", "createdAt"]
    },
    "ConnectedAccount": {
      "title": "Connected Account",
      "description": "An external bank or mobile money account linked to the tracker.",
      "type": "object",
      "properties": {
        "provider": {
          "type": "string",
          "description": "Provider name (e.g., MTN, Telecel, GCB Bank)."
        },
        "accountType": {
          "type": "string",
          "description": "Type of account (bank or mobile_money)."
        },
        "accountMask": {
          "type": "string",
          "description": "Last few digits of the account for display."
        },
        "status": {
          "type": "string",
          "description": "Current sync status (active, disconnected, error)."
        },
        "lastSynced": {
          "type": "string",
          "format": "date-time",
          "description": "Last time transactions were pulled."
        },
        "userId": {
          "type": "string",
          "description": "Owner UID."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Creation timestamp."
        }
      },
      "required": ["provider", "accountType", "userId", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data."
    },
    "/users/{userId}/expenses/{expenseId}": {
      "schema": "Expense",
      "description": "Expenses for a specific user."
    },
    "/users/{userId}/incomes/{incomeId}": {
      "schema": "Income",
      "description": "Incomes for a specific user."
    },
    "/users/{userId}/budgets/{budgetId}": {
      "schema": "Budget",
      "description": "Budgets for a specific user."
    },
    "/users/{userId}/accounts/{accountId}": {
      "schema": "ConnectedAccount",
      "description": "Linked financial accounts."
    }
  }
}
