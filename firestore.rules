rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---

    function isValidExpense(data) {
      return data.amount is number && 
             data.amount > 0 &&
             data.category is string && data.category.size() <= 100 &&
             data.date is string && data.date.size() <= 64 &&
             data.description is string && data.description.size() <= 500 &&
             data.userId == request.auth.uid &&
             data.keys().hasAll(['amount', 'category', 'date', 'description', 'userId', 'createdAt']) &&
             data.keys().size() == 6;
    }

    function isValidIncome(data) {
      return data.amount is number && 
             data.amount > 0 &&
             data.source is string && data.source.size() <= 100 &&
             data.date is string && data.date.size() <= 64 &&
             data.userId == request.auth.uid &&
             data.keys().hasAll(['amount', 'source', 'date', 'userId', 'createdAt']) &&
             data.keys().size() == 5;
    }

    function isValidBudget(data) {
      return data.amount is number && 
             data.amount >= 0 &&
             data.month is number && data.month >= 0 && data.month <= 11 &&
             data.year is number && data.year >= 2000 && data.year <= 2100 &&
             data.userId == request.auth.uid;
    }

    function isValidAccount(data) {
      return data.name is string && data.name.size() <= 100 &&
             data.type in ['bank', 'mobile_money'] &&
             data.userId == request.auth.uid &&
             data.keys().hasAll(['name', 'type', 'userId', 'createdAt', 'accountNumber', 'lastSync']) &&
             data.keys().size() == 6;
    }

    // --- Collection Routes ---

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /expenses/{expenseId} {
      allow read: if isSignedIn() && isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(expenseId) && isValidExpense(incoming()) && incoming().createdAt == request.time;
      allow update: if isSignedIn() && isOwner(existing().userId) && incoming().userId == existing().userId && isValidExpense(incoming());
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }

    match /income/{incomeId} {
      allow read: if isSignedIn() && isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(incomeId) && isValidIncome(incoming()) && incoming().createdAt == request.time;
      allow update: if isSignedIn() && isOwner(existing().userId) && incoming().userId == existing().userId && isValidIncome(incoming());
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }

    match /budgets/{budgetId} {
      allow read: if isSignedIn() && isOwner(existing().userId);
      allow create, update: if isSignedIn() && 
                             budgetId.startsWith(request.auth.uid) && 
                             isValidBudget(incoming());
    }

    match /accounts/{accountId} {
      allow read: if isSignedIn() && isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(accountId) && isValidAccount(incoming()) && incoming().createdAt == request.time;
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }
  }
}
